{
  "manifest_version": 3,
  "name": "Teams Quoted Reply Button",
  "version": "1.0.0",
  "description": "Mueve el botón 'Responder con una cita' al menú principal de acciones de mensaje en Microsoft Teams",
  "permissions": [],
  "host_permissions": [
    "https://teams.microsoft.com/*",
    "https://*.teams.microsoft.com/*",
    "https://teams.live.com/*",
    "https://teams.cloud.microsoft/*",
    "https://*.teams.cloud.microsoft/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://teams.microsoft.com/*",
        "https://*.teams.microsoft.com/*",
        "https://teams.live.com/*",
        "https://teams.cloud.microsoft/*",
        "https://*.teams.cloud.microsoft/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
